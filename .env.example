# Supabase (see your Supabase project settings)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PASSWORD=

# Resend — contact form (https://resend.com)
# Never commit real keys. For local dev, add these to .env.local
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional. Defaults to SPARC test sender if unset:
# RESEND_FROM_EMAIL=SPARC Contact <onboarding@resend.dev>
# Inbox that receives form submissions. Defaults to contact page email in code.
# IMPORTANT (Resend test mode): With onboarding@resend.dev you can ONLY send TO the
# email on your Resend account. For local testing, set this to that email, e.g.:
# CONTACT_TO_EMAIL=you@example.com
# For production, verify a domain at https://resend.com/domains then set FROM + TO:
# RESEND_FROM_EMAIL=SPARC <hello@your-verified-domain.com>
# CONTACT_TO_EMAIL=sparc.calculator@gmail.com
